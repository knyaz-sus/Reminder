{
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src/*", "src/**/*", "env.d.ts", "src/index.ts"],
  "exclude": ["node_modules"]
}
